<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.CalculatorController">    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label fx:id="lblDistance" text="Distance (km)"/>
    <TextField fx:id="txtDistance" promptText="Enter distance"/>

    <Label fx:id="lblConsumption" text="Fuel Consumption (L/100 km)"/>
    <TextField fx:id="txtConsumption" promptText="Enter consumption"/>

    <Label fx:id="lblPrice" text="Fuel Price (per liter)"/>
    <TextField fx:id="txtPrice" promptText="Enter price"/>

    <Button fx:id="btnCalculate" text="Calculate" onAction="#calculate"/>
    <Label fx:id="lblResult" text="Result will appear here"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnEN" text="EN" onAction="#switchToEnglish"/>
        <Button fx:id="btnFR" text="FR" onAction="#switchToFrench"/>
        <Button fx:id="btnJP" text="JP" onAction="#switchToJapanese"/>
        <Button fx:id="btnIR" text="IR" onAction="#switchToPersian"/>
    </HBox>
</VBox>